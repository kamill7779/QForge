APP_BIND_HOST=0.0.0.0
APP_NODE_IP=10.0.0.15
DOCKER_NETWORK_NAME=qforge-remote-net

# Remote middleware endpoints
MYSQL_HOST=10.0.0.6
MYSQL_PORT=13306
MYSQL_DB=qforge
MYSQL_USER=qforge
MYSQL_PASSWORD=qforge

REDIS_HOST=10.0.0.6
REDIS_PORT=16379

RABBITMQ_HOST=10.0.0.6
RABBITMQ_PORT=15674
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_MANAGEMENT_PORT=15673

NACOS_SERVER_ADDR=10.0.0.6:8848
NACOS_HTTP_BASE=http://10.0.0.6:8848
NACOS_USERNAME=
NACOS_PASSWORD=

# Tencent COS for exam-parse-service / ocr-service
# Recommended identity: Tencent Cloud sub-account `qforge-service` under account 100017604744
QFORGE_STORAGE_COS_BUCKET=qforge-2026-1304896342
QFORGE_STORAGE_COS_REGION=ap-shanghai
QFORGE_STORAGE_COS_ENDPOINT=https://qforge-2026-1304896342.cos.ap-shanghai.myqcloud.com
QFORGE_STORAGE_COS_SECRET_ID=
QFORGE_STORAGE_COS_SECRET_KEY=

# Gateway/Auth
START_GATEWAY=true
START_AUTH=false
JWT_SECRET=qforge-super-secret-key-please-change-in-production-1234567890

# AI credentials
ZHIPUAI_API_KEY=
GLM_OCR_API_KEY=
GLM_OCR_ENDPOINT=https://api.z.ai/api/paas/v4/layout_parsing
GLM_OCR_MODEL=glm-ocr
ZHIPUAI_MODEL=glm-5
STEMXML_MODEL=glm-4-0520
EXAMPARSE_AI_MODEL=glm-4-plus

# Export sidecar
START_EXPORT_SIDECAR=true
EXPORT_SIDECAR_PORT=8092
EXAM_EXPORT_SIDECAR_BASE_URL=http://10.0.0.15:8092

# Local ports
GATEWAY_PORT=8080
QUESTION_CORE_PORT=8089
OCR_PORT=8090
PERSIST_PORT=8091
EXAM_PORT=8093
EXAM_PARSE_PORT=8094
QUESTION_BASKET_PORT=8097

# Reduced JVM settings for a 4C / 3.6 GiB host
JAVA_OPTS_GATEWAY='-Xms128m -Xmx256m'
JAVA_OPTS_QUESTION_CORE='-Xms128m -Xmx256m'
JAVA_OPTS_OCR='-Xms192m -Xmx384m -Djava.net.preferIPv4Stack=true'
JAVA_OPTS_PERSIST='-Xms96m -Xmx192m'
JAVA_OPTS_EXAM='-Xms128m -Xmx256m'
JAVA_OPTS_EXAM_PARSE='-Xms128m -Xmx256m'
JAVA_OPTS_QUESTION_BASKET='-Xms96m -Xmx192m'

MAVEN_FLAGS=-DskipTests
