# ===== Fill These First =====
SELF_PUBLIC_IP=REPLACE_WITH_HOST_PUBLIC_IP
SELF_PRIVATE_IP=REPLACE_WITH_HOST_PRIVATE_IP
GATEWAY_PUBLIC_IP=REPLACE_WITH_GATEWAY_HOST_PUBLIC_IP
SIDECAR_PUBLIC_IP=REPLACE_WITH_SIDECAR_HOST_PUBLIC_IP
QDRANT_PUBLIC_IP=REPLACE_WITH_QDRANT_HOST_PUBLIC_IP

COMPOSE_PROFILES=infra

MYSQL_ROOT_PASSWORD=root
MYSQL_DB=qforge
MYSQL_USER=qforge
MYSQL_PASSWORD=replace-me
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
NACOS_USERNAME=
NACOS_PASSWORD=
JWT_SECRET=replace-me-with-64-chars

MYSQL_BIND_PORT=13306
REDIS_BIND_PORT=16379
RABBITMQ_BIND_PORT=15674
RABBITMQ_MANAGEMENT_BIND_PORT=15673
NACOS_BIND_PORT=8848
QDRANT_PORT=6333

ZHIPUAI_API_KEY=
GLM_OCR_API_KEY=
GLM_OCR_ENDPOINT=https://api.z.ai/api/paas/v4/layout_parsing
GLM_OCR_MODEL=glm-ocr
ZHIPUAI_MODEL=glm-5
STEMXML_MODEL=glm-4-0520
EXAMPARSE_AI_MODEL=glm-4-plus

# ===== Derived Variables =====
APP_PUBLIC_HOST=${SELF_PUBLIC_IP}
APP_LOCAL_IP=${SELF_PRIVATE_IP}

MYSQL_HOST=127.0.0.1
MYSQL_PORT=13306

REDIS_HOST=127.0.0.1
REDIS_PORT=16379

RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=15674

NACOS_SERVER_ADDR=127.0.0.1:8848

EXAM_EXPORT_SIDECAR_BASE_URL=http://${SIDECAR_PUBLIC_IP}:8092
FRONTEND_GATEWAY_UPSTREAM=${GATEWAY_PUBLIC_IP}:8080
GAOKAO_FRONTEND_GATEWAY_UPSTREAM=${GATEWAY_PUBLIC_IP}:8080
QDRANT_HOST=${QDRANT_PUBLIC_IP}
