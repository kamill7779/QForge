# ===== Fill These First =====
SELF_PUBLIC_IP=REPLACE_WITH_HOST_PUBLIC_IP
SELF_PRIVATE_IP=REPLACE_WITH_HOST_PRIVATE_IP
INFRA_PUBLIC_IP=REPLACE_WITH_INFRA_PUBLIC_IP
GATEWAY_PUBLIC_IP=REPLACE_WITH_GATEWAY_HOST_PUBLIC_IP
SIDECAR_PUBLIC_IP=REPLACE_WITH_SIDECAR_HOST_PUBLIC_IP

COMPOSE_PROFILES=ai

MYSQL_DB=qforge
MYSQL_USER=qforge
MYSQL_PASSWORD=replace-me
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
NACOS_USERNAME=
NACOS_PASSWORD=
JWT_SECRET=replace-me-with-64-chars

OCR_PORT=8090
GAOKAO_CORPUS_PORT=8095
GAOKAO_ANALYSIS_PORT=8096
QDRANT_PORT=6333

ZHIPUAI_API_KEY=
GLM_OCR_API_KEY=
GLM_OCR_ENDPOINT=https://api.z.ai/api/paas/v4/layout_parsing
GLM_OCR_MODEL=glm-ocr
ZHIPUAI_MODEL=glm-5
STEMXML_MODEL=glm-4-0520
EXAMPARSE_AI_MODEL=glm-4-plus

# ===== Derived Variables =====
APP_PUBLIC_HOST=${SELF_PUBLIC_IP}
APP_LOCAL_IP=${SELF_PRIVATE_IP}

MYSQL_HOST=${INFRA_PUBLIC_IP}
MYSQL_PORT=13306

REDIS_HOST=${INFRA_PUBLIC_IP}
REDIS_PORT=16379

RABBITMQ_HOST=${INFRA_PUBLIC_IP}
RABBITMQ_PORT=15674

NACOS_SERVER_ADDR=${INFRA_PUBLIC_IP}:8848

JAVA_OPTS_OCR='-Xms192m -Xmx384m -Djava.net.preferIPv4Stack=true'
JAVA_OPTS_GAOKAO_CORPUS='-Xms128m -Xmx256m'
JAVA_OPTS_GAOKAO_ANALYSIS='-Xms192m -Xmx384m'

QDRANT_HOST=127.0.0.1
EXAM_EXPORT_SIDECAR_BASE_URL=http://${SIDECAR_PUBLIC_IP}:8092
FRONTEND_GATEWAY_UPSTREAM=${GATEWAY_PUBLIC_IP}:8080
GAOKAO_FRONTEND_GATEWAY_UPSTREAM=${GATEWAY_PUBLIC_IP}:8080
